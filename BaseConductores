procedure MainMenu;
var
  opt: Char;
  i: Integer;
begin
  repeat
    DrawHeader('Menu principal - Base de datos de conductores');
    TextColor(White);
    WriteLn('1) Ver lista de conductores');
    WriteLn('2) Agregar conductor');
    WriteLn('3) Editar conductor');
    WriteLn('4) Eliminar conductor');
    WriteLn('5) Buscar conductor');
    WriteLn('6) Imprimir reporte (archivo .prn)');
    WriteLn('7) Exportar reporte a PDF (archivo de texto .pdf)');
    WriteLn('8) Importar datos de ejemplo (muestra)');
    WriteLn('9) Animacion / Demo audiovisual');
    WriteLn('0) Salir y cerrar');
    TextColor(LightMagenta);
    Write('Seleccione opción: ');
    opt := ReadKey;
    WriteLn(opt);
    case opt of
      '1': ListConductors;
      '2': AddConductor;
      '3': EditConductor;
      '4': DeleteConductor;
      '5': SearchConductor;
      '6': PrintReport;
      '7': ExportReportToFile(ReportFileName);
      '8': ImportSampleData;
      '9': begin
             ClrScr;
             DrawHeader('Demo audiovisual');
             TextColor(LightCyan);
             WriteLn('Iniciando demo: animacion de campo electromagnetico (simulada).');
             WriteLn;
             TextColor(Green);
             for i := 1 to 60 do
               begin
                 GotoXY(10 + (i mod (ScreenWidth - 20)), 10 + Round(5 * Sin(i / 3.0)));
                 Write(#176);
                 Delay(35);
               end;
             WaitKey;
           end;
      '0': begin
             ClrScr;
             TextColor(LightRed);
             WriteLn('Cerrando aplicación. Guardando y cerrando archivos...');
             Close(DB);
             Halt;
           end;
    else
      begin
        TextColor(Red);
        WriteLn('Opción no válida. Intente nuevamente.');
        Delay(400);
      end;
    end;
  until False;
end;

{ -------------------------
  Programa principal
  ------------------------- }
begin
  TextBackground(Black);
  ClrScr;
  ShowSplash;
  InitDB;
  MainMenu;
end.
