(* ========================================================================== *)
(* FUNCIONES PARA NUMEROS COMPLEJOS                                           *)
(* ========================================================================== *)

// Crea un número complejo a partir de sus partes real e imaginaria
FUNCTION C(RealPart, ImagPart: Real): TComplex;
BEGIN
    C.R := RealPart;
    C.I := ImagPart;
END;

// Suma de dos números complejos: Res = A + B
FUNCTION C_Add(A, B: TComplex): TComplex;
BEGIN
    C_Add.R := A.R + B.R;
    C_Add.I := A.I + B.I;
END;

// Resta de dos números complejos: Res = A - B
FUNCTION C_Sub(A, B: TComplex): TComplex;
BEGIN
    C_Sub.R := A.R - B.R;
    C_Sub.I := A.I - B.I;
END;

// Multiplicación de dos números complejos: Res = A * B
FUNCTION C_Mul(A, B: TComplex): TComplex;
VAR
    Resultado: TComplex;
BEGIN
    Resultado.R := A.R * B.R - A.I * B.I;
    Resultado.I := A.R * B.I + A.I * B.R;
    C_Mul := Resultado;
END;

// Inverso de un número complejo: Res = 1 / A
FUNCTION C_Inv(A: TComplex): TComplex;
VAR
    Denom: Real;
    Resultado: TComplex;
BEGIN
    Denom := Sqr(A.R) + Sqr(A.I);
    IF Denom = 0 THEN
    BEGIN
        Resultado.R := 0;
        Resultado.I := 0;
    END
    ELSE
    BEGIN
        Resultado.R := A.R / Denom;
        Resultado.I := -A.I / Denom;
    END;
    C_Inv := Resultado;
END;

// División de dos números complejos: Res = A / B
FUNCTION C_Div(A, B: TComplex): TComplex;
BEGIN
    C_Div := C_Mul(A, C_Inv(B));
END;

// Magnitud (valor absoluto) de un número complejo
FUNCTION C_Abs(A: TComplex): Real;
BEGIN
    C_Abs := Sqrt(Sqr(A.R) + Sqr(A.I));
END;

// Ángulo de un número complejo en grados
FUNCTION C_Angle_Deg(A: TComplex): Real;
CONST
    RAD_A_GRADOS = 180 / PI;
VAR
    AnguloRad: Real;
BEGIN
    IF A.R = 0 THEN
    BEGIN
        IF A.I > 0 THEN AnguloRad := PI / 2
        ELSE IF A.I < 0 THEN AnguloRad := -PI / 2
        ELSE AnguloRad := 0;
    END
    ELSE
    BEGIN
        AnguloRad := ArcTan(A.I / A.R);
        // Ajuste de cuadrante
        IF (A.R < 0) THEN
            AnguloRad := AnguloRad + PI;
    END;
    C_Angle_Deg := AnguloRad * RAD_A_GRADOS;
END;

// Imprime un número complejo en formato rectangular (R + jI)
PROCEDURE C_Print(Z: TComplex; Dec: Integer);
BEGIN
    IF Z.I >= 0 THEN
        Write(Z.R:0:Dec, ' + j', Z.I:0:Dec)
    ELSE
        Write(Z.R:0:Dec, ' - j', Abs(Z.I):0:Dec);
END;

// Imprime un número complejo en formato polar (Mag < Ang°)
PROCEDURE C_Print_Polar(Z: TComplex; Dec: Integer);
BEGIN
    Write(C_Abs(Z):0:Dec, ' < ', C_Angle_Deg(Z):0:2, ' deg');
END;

