{-----------------------------------------------------------------}
procedure cadd(var c:complex; a,b:complex);     {sumar complejos}
begin { cadd }
  c.r := a.r + b.r;
  c.i := a.i + b.i;
end; { cadd }
{------------------------------------------------------------------}
procedure csub(var c:complex; a,b:complex);     {restar complejos}
begin { csub }
  c.r := a.r - b.r;
  c.i := a.i - b.i;
end; { csub }
{--------------------------------------------------------------------}
procedure conj(var c:complex; a:complex);       {conjuncion complejos}
begin { conj }
  c.r := a.r;
  c.i := -a.i;
end; { conj }
{-----------------------------------------------------------------------}
procedure cmult(var c:complex; a,b:complex);     {multiplicacion complejos}
begin { cmult }
  c.r := a.r * b.r - a.i * b.i;
  c.i := a.r * b.i + a.i * b.r;
end; { cmult }
{----------------------------------------------------------------------}
procedure scale(var c:complex; a:real; b:complex);
begin { scale }
  c.r := a * b.r;                               {                     }
  c.i := a * b.i;
end; { scale }
{--------------------------------------------------------------------}
procedure cdiv(var c:complex; a,b:complex);      {division complejos}
var
    rbmag2:real;
begin { cdiv }
  rbmag2 := 1.0 / (b.r * b.r + b.i * b.i);
  c.r := rbmag2 * (a.r * b.r + a.i * b.i);
  c.i := rbmag2 * (b.r * a.i - a.r * b.i);
end; { cdiv }
{------------------------------------------------------------------------}
procedure cmag( var c:real; a:complex );         {magnitud de un numero imaginario}
begin
    c := sqrt( a.r * a.r  +  a.i * a.i );
end;
{-------------------------------------------------------------------------}
procedure cart_to_polar(var c:polar; a:complex);  {transforma de complejos a polar}
begin
  c.m := sqrt(a.r * a.r + a.i * a.i);
  c.a := arctan(a.i / a.r);
end; { cart_to_polar }
{-----------------------------------------------------------------------}
procedure polar_to_cart(var c:complex; a:polar);  {transforma de polar a complejos}
begin
  c.r := a.m * cos(a.a);
  c.i := a.m * sin(a.a);
end; { polar_to_cart }
{--------------------------------------------------------------------------}
procedure factor_potencia(var c:real; a,b:real);  {calcular factor de potencia}
begin
   c := b/a
end; { factor_potencia }




