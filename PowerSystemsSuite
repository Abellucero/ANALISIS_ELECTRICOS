procedure numinput(var value:real);
{Esta rutina maneja la entrada de números reales por teclado.}
var
    number_string : string[20];
    code, i, remainder : integer;
    input_string : string[20];
    decimal_found : boolean ;
label terminate;
begin
for i:= 1 to 20 do input_string[i] := ' '; decimal_found := false;
readln( input_string );
{
si la cadena tiene longitud cero,
el usuario simplemente presiona la tecla Enter, establece el resultado en 0.0 y regresa
}
if length( input_string ) = 0 then
          begin
          number_string := '0.0';
          goto terminate
          end;
i := 0;        { Encuentra el primer carácter que no esté en blanco }
remainder := length( input_string );
repeat
i := i + 1;
remainder := remainder - 1;
until ( input_string[i] <> ' ') or ( remainder = 0 );
{
Si el último carácter de la cadena está en blanco, el campo estaba en blanco
Establezca la cadena en 0.0
}
if input_string[i] = ' ' then
          begin
          number_string := '0.0';
          goto terminate
          end;
{Si el resto = 0 el usuario ingresó solo un número}
if remainder = 0 then
          begin
          number_string := input_string + '.0';
          goto terminate
          end;
{ Coloque un cero a la izquierda del número, detrás del signo menos si el número es negativo }
if input_string[i] = '-' then number_string := '-0'
                       else number_string := '0' + input_string[i]; if
input_string[i] = '.' then decimal_found := true;
{ Copiar número a matriz de cadenas de números }
repeat
i := i + 1;
if input_string[i] <>' ' then
    begin
    number_string := number_string + input_string[i];
    if input_string[i] = '.' then decimal_found := true
    end;
until i = length( input_string );
{Verifique la presencia del punto decimal; si no hay ninguno, agregue uno; de lo contrario, agregue un cero}
if decimal_found then number_string := number_string + '0'
                 else number_string := number_string + '.0';
terminate:
val(number_string, value, code);    {llamado, donde esta la subrutina?}
end; { End numinput procedure }

