PROCEDURE Run_PowerFactorCorrector;

TYPE
    TCalculoFP = RECORD
        DescripcionSistema : STRING[50];
        PotenciaActiva     : REAL; // En kW
        FP_Inicial         : REAL;
        FP_Corregido       : REAL;
        PotenciaReactiva   : REAL; // En kVAr
    END;

VAR
    Casos: ARRAY[1..MAX_CASOS_FP] OF TCalculoFP;
    ContadorCasos: INTEGER;
    Opcion: CHAR;
    NombreArchivo: STRING[20];

    FUNCTION TanDelArcCos(fp: REAL): REAL;
    BEGIN
        IF (fp > 0) AND (fp < 1) THEN
            TanDelArcCos := Sqrt(1 - Sqr(fp)) / fp  (* CORREGIDO: System.Sqrt -> Sqrt *)
        ELSE
            TanDelArcCos := 0;
    END;

    PROCEDURE RealizarCalculo;
    VAR
        NuevoCalculo: TCalculoFP;
        tanInicial, tanFinal: REAL;
    BEGIN
        ClrScr;
        DrawHeader('Calculo de Correccion de Factor de Potencia', Yellow, LightBlue);
        Write('Descripcion del sistema (e.g., Motor 1): '); Readln(NuevoCalculo.DescripcionSistema);
        Write('Potencia Activa (P) en kW: '); Readln(NuevoCalculo.PotenciaActiva);
        Write('Factor de Potencia Inicial (cos φ1) [e.g., 0.85]: '); Readln(NuevoCalculo.FP_Inicial);
        Write('Factor de Potencia Deseado (cos φ2) [e.g., 0.95]: '); Readln(NuevoCalculo.FP_Corregido);

        IF (NuevoCalculo.FP_Inicial >= NuevoCalculo.FP_Corregido) OR
           (NuevoCalculo.FP_Inicial <= 0) OR (NuevoCalculo.FP_Inicial > 1) OR
           (NuevoCalculo.FP_Corregido <= 0) OR (NuevoCalculo.FP_Corregido > 1) THEN
        BEGIN
            TextColor(Red);
            WriteLn;
            WriteLn('Error: Los valores del factor de potencia no son validos.');
            WriteLn('Asegurese de que 0 < FP Inicial < FP Corregido <= 1.');
            ReadKey;
            EXIT;
        END;

        tanInicial := TanDelArcCos(NuevoCalculo.FP_Inicial);
        tanFinal   := TanDelArcCos(NuevoCalculo.FP_Corregido);
        NuevoCalculo.PotenciaReactiva := NuevoCalculo.PotenciaActiva * (tanInicial - tanFinal);

        TextColor(Green);
        WriteLn;
        WriteLn('------------------ RESULTADO DEL CALCULO ------------------');
        TextColor(White);
        WriteLn('Potencia Reactiva del capacitor a instalar (Qc): ', NuevoCalculo.PotenciaReactiva:0:2, ' kVAr');
        TextColor(Green);
        WriteLn('-----------------------------------------------------------');

        IF ContadorCasos < MAX_CASOS_FP THEN
        BEGIN
            Inc(ContadorCasos);
            Casos[ContadorCasos] := NuevoCalculo;
            TextColor(Cyan);
            WriteLn('>>> Calculo almacenado en memoria (Caso #', ContadorCasos, ').');
        END ELSE WriteLn('>>> La lista de casos esta llena. No se pudo almacenar.');

        TextColor(Yellow); WriteLn;
        Write('Presione cualquier tecla para continuar...');
        ReadKey;
    END;

    PROCEDURE MostrarCasos;
    VAR i: INTEGER;
    BEGIN
        ClrScr;
        DrawHeader('Casos de Correccion Almacenados', Yellow, LightBlue);
        IF ContadorCasos = 0 THEN
            WriteLn('No hay casos almacenados en la memoria.')
        ELSE
            FOR i := 1 TO ContadorCasos DO
            BEGIN
                TextColor(LightGreen);
                WriteLn('-------------------- CASO #', i, ' --------------------');
                TextColor(White);
                WriteLn(' Descripcion: ', Casos[i].DescripcionSistema);
                WriteLn(' Potencia Activa (P): ', Casos[i].PotenciaActiva:0:2, ' kW');
                WriteLn(' FP Inicial: ', Casos[i].FP_Inicial:0:2, ' -> FP Corregido: ', Casos[i].FP_Corregido:0:2);
                TextColor(Yellow);
                WriteLn(' Capacitor Requerido (Qc): ', Casos[i].PotenciaReactiva:0:2, ' kVAr');
                WriteLn;
            END;
        TextColor(Yellow);
        Write('Presione cualquier tecla para continuar...');
        ReadKey;
    END;

    PROCEDURE GenerarArchivo;
    VAR Archivo: TEXT; i: INTEGER;
    BEGIN
        ClrScr;
        DrawHeader('Generacion de Archivo de Reporte', Yellow, LightBlue);
        IF ContadorCasos = 0 THEN
        BEGIN
            TextColor(Red);
            WriteLn('No hay casos para guardar en el archivo.');
        END
        ELSE
        BEGIN
            Assign(Archivo, NombreArchivo);
            Rewrite(Archivo);
            Writeln(Archivo, '****************************************************');
            Writeln(Archivo, '* REPORTE DE CORRECCION DE FACTOR DE POTENCIA    *');
            Writeln(Archivo, '****************************************************');
            Writeln(Archivo);
            FOR i := 1 TO ContadorCasos DO
            BEGIN
                Writeln(Archivo, '-------------------- CASO #', i, ' --------------------');
                Writeln(Archivo, ' Descripcion del Sistema   : ', Casos[i].DescripcionSistema);
                Writeln(Archivo, ' Potencia Activa (P)       : ', Casos[i].PotenciaActiva:0:2, ' kW');
                Writeln(Archivo, ' Factor de Potencia Inicial : ', Casos[i].FP_Inicial:0:2);
                Writeln(Archivo, ' Factor de Potencia Corregido: ', Casos[i].FP_Corregido:0:2);
                Writeln(Archivo, ' Capacitor Requerido (Qc)  : ', Casos[i].PotenciaReactiva:0:2, ' kVAr');
                Writeln(Archivo, '-------------------------------------------------');
                Writeln(Archivo);
            END;
            Close(Archivo);
            TextColor(Green);
            WriteLn('Se ha generado el archivo "', NombreArchivo, '" con ', ContadorCasos, ' casos.');
            WriteLn('Este archivo esta listo para ser impreso.');
        END;
        TextColor(Yellow);
        WriteLn; Write('Presione cualquier tecla para continuar...');
        ReadKey;
    END;

BEGIN // Flujo principal de Run_PowerFactorCorrector
    ContadorCasos := 0;
    NombreArchivo := 'ResCapacitor.TXT';
    REPEAT
        ClrScr;
        DrawHeader('Correccion de Factor de Potencia', Yellow, LightBlue);
        WriteLn('1. Realizar un nuevo calculo');
        WriteLn('2. Ver todos los casos almacenados');
        WriteLn('3. Generar archivo de reporte');
        WriteLn('S. Salir al Menu Principal');
        WriteLn;
        TextColor(Cyan);
        Write('Seleccione una opcion: ');
        Opcion := UpCase(ReadKey);
        WriteLn(Opcion);

        CASE Opcion OF
            '1': RealizarCalculo;
            '2': MostrarCasos;
            '3': GenerarArchivo;
        END;
    UNTIL Opcion = 'S';
END;


