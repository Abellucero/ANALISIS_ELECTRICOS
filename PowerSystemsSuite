PROCEDURE Run_ShortCircuitAnalyzer;

CONST
  MaxN = 30;     // Tamaño máximo de la matriz
  Epsilon = 1E-15; // Un valor pequeño para comparaciones con cero

TYPE
  Complex = RECORD
    Re, Im: Real;
  END;

  Matrix = ARRAY[1..MaxN, 1..MaxN] OF Complex;
  Vector = ARRAY[1..MaxN] OF Complex;
  PermutationVector = ARRAY[1..MaxN] OF Integer;

VAR
  // Matrices principales del sistema
  Ybus_pos, Ybus_neg, Ybus_cero : Matrix;
  Zbus_pos, Zbus_neg, Zbus_cero : Matrix;

  // Variables globales del sistema
  N : Integer; // Dimensión actual del sistema (número de buses)
  BaseMVA : Real;
  BaseKV : Real;
  DatosCargados : Boolean;
  ZbusCalculadas : Boolean;

  // Variables para la inversion de matrices
  A, L, U, InvA : Matrix;
  P : PermutationVector;
  b, x : Vector;
  detSign : Real;

  // Variables para almacenar los resultados de la última falla
  UltimoTipoFalla : STRING[30];
  UltimoBusFalla : Integer;
  UltimaCorrienteFalla : Complex;
  UltimosVoltajesPostFalla : Vector; // Almacena el voltaje de fase 'a' post-falla
  ResultadosListosParaGuardar : Boolean;

  // Operadores de secuencia
  Operador_a, Operador_a2 : Complex;

{--------------------------------------------------------------------------}
{ FUNCIONES PARA ARITMÉTICA DE NÚMEROS COMPLEJOS                           }
{--------------------------------------------------------------------------}
FUNCTION Cmplx(r, i: Real): Complex;
BEGIN
  Cmplx.Re := r;
  Cmplx.Im := i;
END;

FUNCTION C_Add(A, B: Complex): Complex;
BEGIN
  C_Add.Re := A.Re + B.Re;
  C_Add.Im := A.Im + B.Im;
END;

FUNCTION C_Sub(A, B: Complex): Complex;
BEGIN
  C_Sub.Re := A.Re - B.Re;
  C_Sub.Im := A.Im - B.Im;
END;

FUNCTION C_Mul(A, B: Complex): Complex;
VAR
  Resultado: Complex;
BEGIN
  Resultado.Re := A.Re * B.Re - A.Im * B.Im;
  Resultado.Im := A.Re * B.Im + A.Im * B.Re;
  C_Mul := Resultado;
END;

FUNCTION C_Abs(A: Complex): Real;
BEGIN
  C_Abs := Sqrt(A.Re * A.Re + A.Im * A.Im);
END;

FUNCTION C_Angle_Deg(A: Complex): Real;
VAR
  AngleRad: Real;
BEGIN
  IF Abs(A.Re) < Epsilon THEN
  BEGIN
    IF Abs(A.Im) < Epsilon THEN AngleRad := 0.0
    ELSE IF A.Im > 0 THEN AngleRad := Pi / 2.0
    ELSE AngleRad := -Pi / 2.0;
  END
  ELSE
  BEGIN
    AngleRad := ArcTan(A.Im / A.Re);
    IF (A.Re < 0) THEN AngleRad := AngleRad + Pi;
  END;
  C_Angle_Deg := AngleRad * 180.0 / Pi;
END;

FUNCTION C_Inv(A: Complex): Complex;
VAR
  Denom: Real;
  Resultado: Complex;
BEGIN
  Denom := A.Re * A.Re + A.Im * A.Im;
  IF Denom < Epsilon THEN
  BEGIN
    WriteLn('Error: Division compleja por cero en C_Inv.');
    Resultado.Re := 1E20;
    Resultado.Im := 1E20;
    C_Inv := Resultado;
    HALT;
  END
  ELSE
  BEGIN
    Resultado.Re := A.Re / Denom;
    Resultado.Im := -A.Im / Denom;
    C_Inv := Resultado;
  END;
END;

FUNCTION C_Div(A, B: Complex): Complex;
BEGIN
  C_Div := C_Mul(A, C_Inv(B));
END;

PROCEDURE ImprimirComplejo(C: Complex; Decimales: Integer);
BEGIN
  Write(C.Re:0:Decimales);
  IF C.Im >= 0 THEN Write(' +j') ELSE Write(' -j');
  Write(Abs(C.Im):0:Decimales);
END;

PROCEDURE ImprimirComplejoPolar(C: Complex; Decimales: Integer);
BEGIN
  Write(C_Abs(C):0:Decimales, ' < ', C_Angle_Deg(C):0:Decimales, ' deg');
END;


{--------------------------------------------------------------------------}
{ PROCEDIMIENTOS PARA MANEJO DE MATRICES Y VECTORES                        }
{--------------------------------------------------------------------------}
PROCEDURE PrintMatrix(VAR M: Matrix; Dim: Integer; Name: String);
VAR i, j: Integer;
BEGIN
  WriteLn;
  WriteLn('Matriz ', Name, ':');
  FOR i := 1 TO Dim DO
  BEGIN
    FOR j := 1 TO Dim DO
    BEGIN
      ImprimirComplejo(M[i,j], 4);
      Write('       ');
    END;
    WriteLn;
  END;
  WriteLn;
END;

PROCEDURE InitializePermutation(VAR pVec: PermutationVector; Dim: Integer);
VAR i: Integer;
BEGIN
  FOR i := 1 TO Dim DO
    pVec[i] := i;
END;

PROCEDURE SwapRows(VAR M: Matrix; r1, r2: Integer; Dim: Integer);
VAR j: Integer;
    temp: Complex;
BEGIN
  IF r1 <> r2 THEN
  BEGIN
    FOR j := 1 TO Dim DO
    BEGIN
      temp := M[r1, j];
      M[r1, j] := M[r2, j];
      M[r2, j] := temp;
    END;
  END;
END;

PROCEDURE SwapPermutation(VAR pVec: PermutationVector; r1, r2: Integer);
VAR temp: Integer;
BEGIN
  IF r1 <> r2 THEN
  BEGIN
    temp := pVec[r1];
    pVec[r1] := pVec[r2];
    pVec[r2] := temp;
  END;
END;

{--------------------------------------------------------------------------}
{ FACTORIZACIÓN LU CON PIVOTEO PARCIAL (PA = LU)                           }
{--------------------------------------------------------------------------}
FUNCTION LUDecomposition(VAR A_LU: Matrix; VAR pVec: PermutationVector; Dim: Integer; VAR sign: Real): Boolean;
VAR
  i, j, k, pivotRow: Integer;
  maxVal: Real;
  factor: Complex;
BEGIN
  sign := 1.0;
  InitializePermutation(pVec, Dim);
  FOR k := 1 TO Dim DO
  BEGIN
    maxVal := 0.0;
    pivotRow := k;
    FOR i := k TO Dim DO
    BEGIN
      IF C_Abs(A_LU[i, k]) > maxVal THEN
      BEGIN
        maxVal := C_Abs(A_LU[i, k]);
        pivotRow := i;
      END;
    END;

    IF maxVal < Epsilon THEN
    BEGIN
      WriteLn('Error: Matriz singular detectada durante la descomposicion LU.');
      LUDecomposition := FALSE;
      Exit;
    END;

    IF pivotRow <> k THEN
    BEGIN
      SwapRows(A_LU, k, pivotRow, Dim);
      SwapPermutation(pVec, k, pivotRow);
      sign := -sign;
    END;

    FOR i := k + 1 TO Dim DO
    BEGIN
      factor := C_Div(A_LU[i, k], A_LU[k, k]);
      A_LU[i, k] := factor;
      FOR j := k + 1 TO Dim DO
      BEGIN
        A_LU[i, j] := C_Sub(A_LU[i, j], C_Mul(factor, A_LU[k, j]));
      END;
    END;
  END;
  LUDecomposition := TRUE;
END;

{--------------------------------------------------------------------------}
{ RESOLUCIÓN DE SISTEMAS TRIANGULARES                                      }
{--------------------------------------------------------------------------}
PROCEDURE ForwardSubstitution(VAR LU: Matrix; VAR b_perm: Vector; VAR y: Vector; Dim: Integer);
VAR i, j: Integer;
    sum: Complex;
BEGIN
  FOR i := 1 TO Dim DO
  BEGIN
    sum := Cmplx(0,0);
    FOR j := 1 TO i - 1 DO
    BEGIN
      sum := C_Add(sum, C_Mul(LU[i, j], y[j]));
    END;
    y[i] := C_Sub(b_perm[i], sum);
  END;
END;

PROCEDURE BackwardSubstitution(VAR LU: Matrix; VAR y: Vector; VAR x_sol: Vector; Dim: Integer);
VAR i, j: Integer;
    sum: Complex;
BEGIN
  FOR i := Dim DOWNTO 1 DO
  BEGIN
    sum := Cmplx(0,0);
    FOR j := i + 1 TO Dim DO
    BEGIN
      sum := C_Add(sum, C_Mul(LU[i, j], x_sol[j]));
    END;
    IF C_Abs(LU[i,i]) < Epsilon THEN
    BEGIN
      WriteLn('Error: Division por cero en BackwardSubstitution.');
      Halt;
    END;
    x_sol[i] := C_Div(C_Sub(y[i], sum), LU[i, i]);
  END;
END;

{--------------------------------------------------------------------------}
{ INVERSIÓN DE LA MATRIZ USANDO FACTORIZACIÓN LU                           }
{--------------------------------------------------------------------------}
FUNCTION InvertMatrix(VAR A_orig: Matrix; VAR A_inv: Matrix; Dim: Integer): Boolean;
VAR
  LU_Fact: Matrix;
  p_Vec: PermutationVector;
  identity_col, perm_identity_col, y_sol, inv_col: Vector;
  i, j, k: Integer;
  success: Boolean;
  s: Real;
BEGIN
  LU_Fact := A_orig;
  success := LUDecomposition(LU_Fact, p_Vec, Dim, s);
  IF NOT success THEN
  BEGIN
    WriteLn('No se pudo calcular la inversa: la matriz es singular.');
    InvertMatrix := FALSE;
    Exit;
  END;

  FOR j := 1 TO Dim DO
  BEGIN
    FOR i := 1 TO Dim DO
    BEGIN
      IF i = j THEN
        identity_col[i] := Cmplx(1,0)
      ELSE
        identity_col[i] := Cmplx(0,0);
    END;

    FOR k := 1 TO Dim DO
      perm_identity_col[k] := identity_col[p_Vec[k]];

    ForwardSubstitution(LU_Fact, perm_identity_col, y_sol, Dim);
    BackwardSubstitution(LU_Fact, y_sol, inv_col, Dim);

    FOR i := 1 TO Dim DO
      A_inv[i, j] := inv_col[i];
  END;
  InvertMatrix := TRUE;
END;

{--------------------------------------------------------------------------}
{ LÓGICA PRINCIPAL DE CÁLCULOS DEL SISTEMA                                 }
{--------------------------------------------------------------------------}

PROCEDURE InicializarValores;
BEGIN
  // Operador a = 1 < 120 deg = -0.5 + j0.8660
  Operador_a.Re := -0.5;
  Operador_a.Im := Sqrt(3)/2.0;

