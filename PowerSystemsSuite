// Dibuja un banner estandarizado para cada módulo
PROCEDURE DrawHeader(Title: String; MainColor, FrameColor: Byte);
VAR
    Bar: String;
    i: Integer;
BEGIN
    Bar := '';
    FOR i := 1 TO 80 DO Bar := Bar + #205; // Caracter ═
    TextBackground(Black);
    TextColor(FrameColor);
    GoToXY(1, 1); Write(Bar);
    GoToXY(1, 3); Write(Bar);

    TextColor(MainColor);
    GoToXY((80 - Length(Title)) DIV 2, 2);
    Write(Title);
    TextColor(White);
    GoToXY(1, 5);
END;

// Dibuja una caja para los menús
PROCEDURE DrawBox(x1, y1, x2, y2: Integer; Color: Byte);
VAR i: Integer;
BEGIN
    TextColor(Color);
    GoToXY(x1, y1); Write(#201); // ╔
    FOR i := x1 + 1 TO x2 - 1 DO Write(#205); // ═
    Write(#187); // ╗

    FOR i := y1 + 1 TO y2 - 1 DO
    BEGIN
        GoToXY(x1, i); Write(#186); // ║
        GoToXY(x2, i); Write(#186); // ║
    END;

    GoToXY(x1, y2); Write(#200); // ╚
    FOR i := x1 + 1 TO x2 - 1 DO Write(#205); // ═
    Write(#188); // ╝
END;


(******************************************************************************)
(* *)
(* MODULO 1: CALCULADORA DE IMPEDANCIAS EN POR UNIDAD (p.u.)                  *)
(* *)
(******************************************************************************)
PROCEDURE Run_PerUnitCalculator;

TYPE
    TResultadoPU = RECORD
        TipoElemento : String[40];
        ImpedanciaPU : TComplex;
    END;

VAR
    Resultados : ARRAY[1..MAX_EPUC_RESULTS] OF TResultadoPU;
    ContadorResultados : Integer;
    Opcion : Char;
    MvaBase, KvBase : Real;
    NombreArchivo : String[12];

    PROCEDURE Banner;
    BEGIN
        DrawHeader('Calculo de Impedancias en Por Unidad (p.u.)', Yellow, LightBlue);
    END;

    PROCEDURE EstablecerValoresBase;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- ESTABLECER VALORES BASE DEL SISTEMA ---');
        TextColor(White);
        Write('Ingrese la Potencia Base del Sistema (MVA): ');
        ReadLn(MvaBase);
        Write('Ingrese el Voltaje Base del Sistema (kV): ');
        ReadLn(KvBase);
        WriteLn;
        TextColor(Green);
        WriteLn('Valores base guardados correctamente.');
        Delay(1500);
    END;

    PROCEDURE CalcularMotoresGeneradores;
    VAR
        Hp, Pf, Eff, KvEq, Xd, XR_Ratio, MvaEq, Z_pu_own_mag, Angulo : Real;
        Z_pu_new : TComplex;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: MOTORES O GENERADORES (> 50 HP) ---');
        TextColor(White);
        Write('Potencia del equipo (HP): '); ReadLn(Hp);
        Write('Factor de Potencia (ej. 0.85): '); ReadLn(Pf);
        Write('Eficiencia (ej. 0.9): '); ReadLn(Eff);
        Write('Voltaje del equipo (kV): '); ReadLn(KvEq);
        Write('Reactancia Subtransitoria (p.u. en su base, ej. 0.15): '); ReadLn(Xd);
        Write('Relacion X/R: '); ReadLn(XR_Ratio);

        MvaEq := (Hp * 0.000746) / (Eff * Pf);
        Z_pu_own_mag := Xd;
        Angulo := ArcTan(XR_Ratio);
        Z_pu_new.R := Z_pu_own_mag * Cos(Angulo) * (MvaBase / MvaEq) * Sqr(KvEq / KvBase);
        Z_pu_new.I := Z_pu_own_mag * Sin(Angulo) * (MvaBase / MvaEq) * Sqr(KvEq / KvBase); (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Motor/Generador >50HP';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu_new;

        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu_new, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE CalcularMotoresMenores50Hp;
    VAR
        HpTotal, Pf, Eff, KvEq, Xd, XR_Ratio, MvaEq, Z_pu_own_mag, Angulo : Real;
        Z_pu_new : TComplex;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: MOTORES AGRUPADOS (< 50 HP) ---');
        TextColor(White);
        Write('Suma de Potencia de los motores (HP Total): '); ReadLn(HpTotal);
        Write('Factor de Potencia promedio (ej. 0.8): '); ReadLn(Pf);
        Write('Eficiencia promedio (ej. 0.85): '); ReadLn(Eff);
        Write('Voltaje del grupo de motores (kV): '); ReadLn(KvEq);
        Write('Reactancia Subtransitoria promedio (p.u., ej. 0.25): '); ReadLn(Xd);
        Write('Relacion X/R promedio: '); ReadLn(XR_Ratio);

        MvaEq := (HpTotal * 0.000746) / (Eff * Pf);
        Z_pu_own_mag := Xd;
        Angulo := ArcTan(XR_Ratio);
        Z_pu_new.R := Z_pu_own_mag * Cos(Angulo) * (MvaBase / MvaEq) * Sqr(KvEq / KvBase);
        Z_pu_new.I := Z_pu_own_mag * Sin(Angulo) * (MvaBase / MvaEq) * Sqr(KvEq / KvBase); (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Motores Agrupados <50HP';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu_new;

        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu_new, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE CalcularTransformadores;
    VAR
        MvaEq, Z_pct, XR_Ratio, Z_pu_own_mag, Angulo: Real;
        Z_pu_new : TComplex;
        TipoDevanado: Char;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: TRANSFORMADORES ---');
        TextColor(White);
        Write('Potencia del transformador (MVA): '); ReadLn(MvaEq);
        Write('Impedancia del transformador (%Z, ej. 5.5): '); ReadLn(Z_pct);
        Write('Relacion X/R: '); ReadLn(XR_Ratio);

        Z_pu_own_mag := Z_pct / 100;
        Angulo := ArcTan(XR_Ratio);
        Z_pu_new.R := Z_pu_own_mag * Cos(Angulo) * (MvaBase / MvaEq);
        Z_pu_new.I := Z_pu_own_mag * Sin(Angulo) * (MvaBase / MvaEq); (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Transformador';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu_new;
        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu_new, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE CalcularCables;
    VAR
        R_ohm_km, X_ohm_km, Longitud, Zbase : Real;
        NumConductores : Integer;
        Z_pu : TComplex;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: CABLES ---');
        TextColor(White);
        Write('Resistencia por km (Ohm/km): '); ReadLn(R_ohm_km);
        Write('Reactancia por km (Ohm/km): '); ReadLn(X_ohm_km);
        Write('Longitud del cable (km): '); ReadLn(Longitud);
        Write('Numero de conductores por fase: '); ReadLn(NumConductores);

        Zbase := Sqr(KvBase) / MvaBase;
        Z_pu.R := (R_ohm_km * Longitud / NumConductores) / Zbase;
        Z_pu.I := (X_ohm_km * Longitud / NumConductores) / Zbase; (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Cable de Potencia';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu;

        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE CalcularLineasSimplificado;
    VAR
        R_ohm, X_ohm, Zbase : Real;
        Z_pu : TComplex;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: LINEAS DE TRANSMISION (SIMPLIFICADO) ---');
        TextColor(White);
        Write('Resistencia total de la linea (Ohm): '); ReadLn(R_ohm);
        Write('Reactancia total de la linea (Ohm): '); ReadLn(X_ohm);

        Zbase := Sqr(KvBase) / MvaBase;
        Z_pu.R := R_ohm / Zbase;
        Z_pu.I := X_ohm / Zbase; (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Linea de Transmision';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu;
        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE CalcularAcometida;
    VAR
        MvaSCC, XR_Ratio, Z_pu_mag, Angulo : Real;
        Z_pu : TComplex;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: ACOMETIDA (UTILIDAD) ---');
        TextColor(White);
        Write('Potencia de Cortocircuito en el punto (MVA SCC): '); ReadLn(MvaSCC);
        Write('Relacion X/R en el punto: '); ReadLn(XR_Ratio);

        Z_pu_mag := MvaBase / MvaSCC;
        Angulo := ArcTan(XR_Ratio);
        Z_pu.R := Z_pu_mag * Cos(Angulo);
        Z_pu.I := Z_pu_mag * Sin(Angulo); (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Acometida (Utilidad)';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu;
        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE CalcularReactores;
    VAR
        X_ohm, Zbase : Real;
        Z_pu : TComplex;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- CALCULO: REACTORES ---');
        TextColor(White);
        Write('Reactancia del reactor (Ohms): '); ReadLn(X_ohm);

        Zbase := Sqr(KvBase) / MvaBase;
        Z_pu.R := 0; // Se asume un reactor ideal sin resistencia
        Z_pu.I := X_ohm / Zbase; (* CORREGIDO: .X -> .I *)

        Inc(ContadorResultados);
        Resultados[ContadorResultados].TipoElemento := 'Reactor';
        Resultados[ContadorResultados].ImpedanciaPU := Z_pu;
        TextColor(Green);
        WriteLn;
        WriteLn('Cálculo completado:');
        Write('Impedancia (p.u.): '); C_Print(Z_pu, 6); WriteLn;
        WriteLn('Resultado guardado.');
        ReadKey;
    END;

    PROCEDURE MostrarResultadosEnPantalla;
    VAR i : Integer;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- RESULTADOS DE CALCULOS ALMACENADOS ---');
        WriteLn;
        TextColor(Yellow);
        WriteLn('No. | TIPO DE ELEMENTO                      | R (p.u.)     | I (p.u.)'); (* CORREGIDO: X -> I *)
        WriteLn('-----------------------------------------------------------------------------');
        TextColor(White);
        IF ContadorResultados = 0 THEN
            WriteLn('No hay resultados para mostrar.')
        ELSE
            FOR i := 1 TO ContadorResultados DO
            BEGIN
                Write(i:3, ' | ');
                Write(Resultados[i].TipoElemento:38, ' | ');
                Write(Resultados[i].ImpedanciaPU.R:12:8, ' | ');
                WriteLn(Resultados[i].ImpedanciaPU.I:12:8); (* CORREGIDO: .X -> .I *)
            END;
        WriteLn;
        WriteLn('Presione cualquier tecla para continuar...');
        ReadKey;
    END;

    PROCEDURE GuardarResultadosEnArchivo;
    VAR
        Archivo : Text;
        i : Integer;
    BEGIN
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- GUARDAR RESULTADOS EN ARCHIVO ---');
        TextColor(White);
        IF ContadorResultados = 0 THEN
        BEGIN
            TextColor(Red);
            WriteLn('No hay resultados para guardar.');
        END
        ELSE
        BEGIN
            Assign(Archivo, NombreArchivo);
            Rewrite(Archivo);
            WriteLn(Archivo,'====================================================================');
            WriteLn(Archivo, '        RESULTADOS DE CALCULO DE IMPEDANCIAS EN POR UNIDAD');
            WriteLn(Archivo, '====================================================================');
            WriteLn(Archivo, 'Valores Base: ', MvaBase:0:2, ' MVA, ', KvBase:0:2, ' kV');
            WriteLn(Archivo, '--------------------------------------------------------------------');
            WriteLn(Archivo, '');
            WriteLn(Archivo, 'Elemento                                 |    R (p.u.) |    I (p.u.)'); (* CORREGIDO: X -> I *)
            WriteLn(Archivo, '--------------------------------------------------------------------');
            FOR i := 1 TO ContadorResultados DO
            BEGIN
                Write(Archivo, Resultados[i].TipoElemento:39);
                Write(Archivo, ' | ', Resultados[i].ImpedanciaPU.R:12:8);
                WriteLn(Archivo, ' | ', Resultados[i].ImpedanciaPU.I:12:8); (* CORREGIDO: .X -> .I *)
            END;
            Close(Archivo);
            TextColor(Green);
            WriteLn('Resultados guardados exitosamente en el archivo "', NombreArchivo, '".');
        END;
        WriteLn;
        WriteLn('Presione cualquier tecla para continuar...');
        ReadKey;
    END;

BEGIN // Flujo principal de Run_PerUnitCalculator
    ContadorResultados := 0;
    MvaBase := 0;
    KvBase := 0;
    NombreArchivo := 'ResPU.txt';

    REPEAT
        ClrScr;
        Banner;
        TextColor(Cyan);
        WriteLn('--- MENU PRINCIPAL DE CALCULOS P.U. ---');
        TextColor(White);
        GoToXY(50,5); Write('Valores Base -> ');
        TextColor(LightGreen); Write('MVA: ', MvaBase:0:2, ' | kV: ', KvBase:0:2); TextColor(White);
        WriteLn;
        WriteLn(' B. Establecer Valores Base (MVA, kV)');
        WriteLn;
        WriteLn(' --- CALCULAR IMPEDANCIA DE: ---');
        WriteLn(' 1. Motores o Generadores (> 50HP)');
        WriteLn(' 2. Motores Agrupados (< 50HP)');
        WriteLn(' 3. Transformadores');
        WriteLn(' 4. Cables');
        WriteLn(' 5. Lineas de Transmision (Simplificado)');
        WriteLn(' 6. Acometida (Utilidad)');
        WriteLn(' 7. Reactores');
        WriteLn;
        WriteLn(' --- SALIDA DE DATOS ---');
        WriteLn(' M. Mostrar Resultados en Pantalla');
        WriteLn(' G. Guardar Resultados en Archivo');
        WriteLn;
        WriteLn(' S. Salir al Menu Principal');
        WriteLn;
        TextColor(Yellow);
        Write('Seleccione una opcion: ');
        TextColor(White);
        Opcion := UpCase(ReadKey);
        WriteLn(Opcion);

        IF (Opcion IN ['1'..'7']) AND (MvaBase = 0) THEN
        BEGIN
            TextColor(Red);
            GoToXY(1, 24); Write('ERROR: Primero debe establecer los valores base (Opcion B).');
            Delay(2000);
            GoToXY(1, 24); ClrEol;
        END
        ELSE
        CASE Opcion OF
            'B': EstablecerValoresBase;
            '1': CalcularMotoresGeneradores;
            '2': CalcularMotoresMenores50Hp;
            '3': CalcularTransformadores;
            '4': CalcularCables;
            '5': CalcularLineasSimplificado;
            '6': CalcularAcometida;
            '7': CalcularReactores;
            'M': MostrarResultadosEnPantalla;
            'G': GuardarResultadosEnArchivo;
            'S': ; // Salir del bucle
            ELSE
            BEGIN
                TextColor(Red);
                GoToXY(1, 24); Write('Opcion no valida. Intente de nuevo.');
                Delay(1000);
                GoToXY(1, 24); ClrEol;
            END;
        END;

    UNTIL Opcion = 'S';
END;


(******************************************************************************)
(* *)
(* MODULO 2: CALCULADORA DE NUMEROS COMPLEJOS                                 *)
(* *)
(******************************************************************************)
PROCEDURE Run_ComplexCalculator;

VAR
    opcion : CHAR;

    PROCEDURE LeerComplejo(VAR z: TComplex; num: INTEGER);
    BEGIN
        Write('Ingrese el Complejo #', num, ' (Forma a+bi)'); WriteLn;
        Write('  Parte Real (a): '); ReadLn(z.R);
        Write('  Parte Imaginaria (b): '); ReadLn(z.I);
        WriteLn;
    END;

    PROCEDURE MostrarResultado(z: TComplex);
    BEGIN
        TextColor(LightGreen);
        WriteLn('----------------------------------------');
        WriteLn('                RESULTADO:');
        WriteLn('----------------------------------------');
        TextColor(White);
        Write(' Forma Binomial: '); C_Print(z, 4); WriteLn;
        Write(' Forma Polar   : '); C_Print_Polar(z, 4); WriteLn;
        WriteLn('----------------------------------------');
        WriteLn;
        TextColor(Yellow);
        Write('Presione una tecla para continuar...');
        ReadKey;
    END;

    PROCEDURE SumarN;
    VAR i, n: INTEGER; z, resultado: TComplex;
    BEGIN
        ClrScr;
        DrawHeader('Suma de N Numeros Complejos', Yellow, LightBlue);
        Write('Cuantos numeros desea sumar?: '); ReadLn(n);
        WriteLn;
        resultado := C(0, 0);
        FOR i := 1 TO n DO
        BEGIN
            LeerComplejo(z, i);
            resultado := C_Add(resultado, z);
        END;
        MostrarResultado(resultado);
    END;

    PROCEDURE RestarN;
    VAR i, n: INTEGER; z, resultado: TComplex;
    BEGIN
        ClrScr;
        DrawHeader('Resta de N Numeros Complejos', Yellow, LightBlue);
        Write('Cuantos numeros desea restar?: '); ReadLn(n);
        WriteLn;
        IF n > 0 THEN
        BEGIN
            LeerComplejo(resultado, 1);
            FOR i := 2 TO n DO
            BEGIN
                LeerComplejo(z, i);
                resultado := C_Sub(resultado, z);
            END;
        END ELSE resultado := C(0, 0);
        MostrarResultado(resultado);
    END;

    PROCEDURE DividirN;
    VAR i, n: INTEGER; z, resultado: TComplex;
    BEGIN
        ClrScr;
        DrawHeader('Division de N Numeros Complejos', Yellow, LightBlue);
        Write('Cuantos numeros desea dividir?: '); ReadLn(n);
        WriteLn;
        IF n > 0 THEN
        BEGIN
            LeerComplejo(resultado, 1);
            FOR i := 2 TO n DO
            BEGIN
                LeerComplejo(z, i);
                resultado := C_Div(resultado, z);
            END;
        END ELSE resultado := C(0, 0);
        MostrarResultado(resultado);
    END;

    PROCEDURE CalcularZEquivalente;
    VAR i, n: INTEGER; z, sumaReciprocos, z_eq: TComplex;
    BEGIN
        ClrScr;
        DrawHeader('Calculo de Z-Equivalente (en Paralelo)', Yellow, LightBlue);
        Write('Cuantas impedancias desea procesar?: '); ReadLn(n);
        WriteLn;
        sumaReciprocos := C(0, 0);
