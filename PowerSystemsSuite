PROCEDURE CalcularYMostrarCorrienteReal(If_pu: Complex);
VAR
  Opcion: Char;
  Ibase, Ireal_kA: Real;
BEGIN
  WriteLn;
  TextColor(Cyan);
  Write('Desea calcular la corriente real en kiloamperes (kA)? (S/N): ');
  Opcion := UpCase(ReadKey);
  WriteLn(Opcion);
  TextColor(White);

  IF Opcion = 'S' THEN
  BEGIN
    Write('Ingrese la Potencia Base del sistema (MVA): ');
    ReadLn(BaseMVA);
    Write('Ingrese el Voltaje Base del bus de falla (kV): ');
    ReadLn(BaseKV);

    IF (BaseMVA <= 0) OR (BaseKV <= 0) THEN
    BEGIN
      WriteLn('Valores base invalidos.');
      Exit;
    END;

    // I_base (kA) = MVA_base / (sqrt(3) * kV_base)
    Ibase := BaseMVA / (Sqrt(3) * BaseKV);
    Ireal_kA := C_Abs(If_pu) * Ibase;

    TextColor(Yellow);
    WriteLn('---------------------------------------------');
    WriteLn('Corriente Base (I_base): ', Ibase:0:4, ' kA');
    WriteLn('Corriente de Falla Real: ', Ireal_kA:0:4, ' kA');
    WriteLn('---------------------------------------------');
    TextColor(White);
  END;
END;


PROCEDURE CalcularFallaTrifasica;
VAR
  Vf_prefalla : Complex;
  If_3ph : Complex;
  Zkk_pos : Complex;
  VoltajesPostFalla : Vector;
  i, BusFalla: Integer;
BEGIN
  ResultadosListosParaGuardar := False;

  IF NOT ZbusCalculadas THEN
  BEGIN
      WriteLn('Error: Debe calcular las matrices Zbus primero.');
      ReadKey;
      Exit;
  END;

  Write('Ingrese el numero del bus a fallar (1-', N, '): ');
  ReadLn(BusFalla);

  IF (BusFalla < 1) OR (BusFalla > N) THEN
  BEGIN
    WriteLn('Numero de bus de falla invalido.');
    Exit;
  END;

  Vf_prefalla := Cmplx(1.0, 0.0);
  Zkk_pos := Zbus_pos[BusFalla, BusFalla];

  IF C_Abs(Zkk_pos) < Epsilon THEN
  BEGIN
    WriteLn('Error: Zbus_pos[k,k] es cero. Division por cero.');
    Exit;
  END;

  If_3ph := C_Div(Vf_prefalla, Zkk_pos);
  UltimaCorrienteFalla := If_3ph;
  UltimoBusFalla := BusFalla;
  UltimoTipoFalla := 'Trifasica Simetrica';

  ClrScr;
  TextColor(Yellow);
  WriteLn('--- Resultados Falla Trifasica en Bus ', BusFalla, ' ---');
  TextColor(White);
  Write('Corriente de Falla Total (If) en p.u.: ');
  ImprimirComplejoPolar(If_3ph, 4);
  Write(' | Rectangular: ');
  ImprimirComplejo(If_3ph, 4);
  WriteLn;

  CalcularYMostrarCorrienteReal(If_3ph);

  WriteLn;
  WriteLn('Voltajes Post-Falla en buses (p.u.):');
  FOR i := 1 TO N DO
  BEGIN
    // La fórmula es V_i(post) = V_i(pre) - Z_ik * I_falla_k
    // Asumiendo V_i(pre) = 1.0 para todos los buses.
    VoltajesPostFalla[i] := C_Sub(Vf_prefalla, C_Mul(Zbus_pos[i,BusFalla], If_3ph));

    // Guardar el resultado para la función de guardar en archivo
    UltimosVoltajesPostFalla[i] := VoltajesPostFalla[i];

    Write('  Bus ', i, ': ');
    ImprimirComplejoPolar(VoltajesPostFalla[i], 4);
    WriteLn;
  END;

  ResultadosListosParaGuardar := True;
  WriteLn;
  WriteLn('Calculo completado. Presione una tecla para volver al menu...');
  ReadKey;
END;

PROCEDURE CalcularFallaLineaTierra;
VAR
  BusFalla: Integer;
  Vf_prefalla: Complex;
  Zkk_pos, Zkk_neg, Zkk_cero, Z_total_sec: Complex;
  Ia1, Ia2, Ia0, If_LG: Complex;
  Vi_pos, Vi_neg, Vi_cero, Via_post: Complex;
  i: Integer;
BEGIN
  ResultadosListosParaGuardar := False;

  IF NOT ZbusCalculadas THEN
  BEGIN
    WriteLn('Error: Debe calcular las matrices Zbus primero.');
    ReadKey;
    Exit;
  END;

  Write('Ingrese el numero del bus a fallar (1-', N, '): ');
  ReadLn(BusFalla);

  IF (BusFalla < 1) OR (BusFalla > N) THEN
  BEGIN
    WriteLn('Numero de bus de falla invalido.');
    Exit;
  END;

  // Voltaje pre-falla es 1.0 p.u.
  Vf_prefalla := Cmplx(1.0, 0.0);

  // Obtener las impedancias de la diagonal de Zbus para el bus fallado
  Zkk_pos := Zbus_pos[BusFalla, BusFalla];
  Zkk_neg := Zbus_neg[BusFalla, BusFalla];
  Zkk_cero := Zbus_cero[BusFalla, BusFalla];

  // Las redes de secuencia se conectan en serie: Z_total = Z1+Z2+Z0
  Z_total_sec := C_Add(Zkk_pos, C_Add(Zkk_neg, Zkk_cero));

  IF C_Abs(Z_total_sec) < Epsilon THEN
  BEGIN
    WriteLn('Error: La impedancia total de secuencia es cero. Division por cero.');
    Exit;
  END;

  // Calcular corrientes de secuencia: Ia1 = Ia2 = Ia0 = Vpre / Z_total
  Ia1 := C_Div(Vf_prefalla, Z_total_sec);
  Ia2 := Ia1;
  Ia0 := Ia1;

  // La corriente de falla a tierra es If = 3 * Ia0
  If_LG := C_Mul(Cmplx(3.0, 0.0), Ia0);

  // Almacenar resultados para la función de guardar
  UltimaCorrienteFalla := If_LG;
  UltimoBusFalla := BusFalla;
  UltimoTipoFalla := 'Linea a Tierra (Monofasica)';

  ClrScr;
  TextColor(Yellow);
  WriteLn('--- Resultados Falla Linea-Tierra en Bus ', BusFalla, ' ---');
  TextColor(White);
  WriteLn;
  Write('Corriente de Falla a Tierra (If) en p.u.: ');
  ImprimirComplejoPolar(If_LG, 4);
  Write(' | Rectangular: ');
  ImprimirComplejo(If_LG, 4);
  WriteLn;

  WriteLn;
  WriteLn('Corrientes de Secuencia en el Bus de Falla (p.u.):');
  Write('  I_a1: '); ImprimirComplejoPolar(Ia1, 4); WriteLn;
  Write('  I_a2: '); ImprimirComplejoPolar(Ia2, 4); WriteLn;
  Write('  I_a0: '); ImprimirComplejoPolar(Ia0, 4); WriteLn;

  CalcularYMostrarCorrienteReal(If_LG);

  WriteLn;
  WriteLn('Voltajes de Fase A Post-Falla en buses (p.u.):');
  FOR i := 1 TO N DO
  BEGIN
    // Calcular voltajes de secuencia en cada bus i
    // V_i1 = Vpre_i - Z_ik1 * I_k1
    // V_i2 = 0        - Z_ik2 * I_k2
    // V_i0 = 0        - Z_ik0 * I_k0
    Vi_pos := C_Sub(Vf_prefalla, C_Mul(Zbus_pos[i, BusFalla], Ia1));
    Vi_neg := C_Mul(Cmplx(-1.0, 0.0), C_Mul(Zbus_neg[i, BusFalla], Ia2));
    Vi_cero := C_Mul(Cmplx(-1.0, 0.0), C_Mul(Zbus_cero[i, BusFalla], Ia0));

    // Calcular voltaje de fase 'a' post-falla: V_ia = V_i1 + V_i2 + V_i0
    Via_post := C_Add(Vi_pos, C_Add(Vi_neg, Vi_cero));

    // Guardar el resultado para la función de guardar en archivo
    UltimosVoltajesPostFalla[i] := Via_post;

    Write('  Bus ', i, ': ');
    ImprimirComplejoPolar(Via_post, 4);
    WriteLn;
  END;

  ResultadosListosParaGuardar := True;
  WriteLn;
  WriteLn('Calculo completado. Presione una tecla para volver al menu...');
  ReadKey;
END;

PROCEDURE GuardarUltimoResultado;
VAR
  Reporte: Text;
  NombreArchivo: STRING;
  i: Integer;
BEGIN
  ClrScr;
  IF NOT ResultadosListosParaGuardar THEN
